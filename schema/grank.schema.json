{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://grank.dev/schema/grank.schema.json",
  "title": "gRank dataset",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "status", "generatedAt", "source", "methodology", "episodes"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "status": { "enum": ["draft", "published"] },
    "generatedAt": { "type": "string", "format": "date-time" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["feedUrl", "youtubeChannelUrl", "catalogEpisodeCount"],
      "properties": {
        "feedUrl": { "type": "string", "format": "uri" },
        "youtubeChannelUrl": { "type": "string", "format": "uri" },
        "feedLastBuildDate": { "type": ["string", "null"], "format": "date-time" },
        "catalogEpisodeCount": { "type": "integer", "minimum": 0 }
      }
    },
    "methodology": {
      "type": "object",
      "additionalProperties": false,
      "required": ["definitionVersion", "detectorVersion"],
      "properties": {
        "definitionVersion": { "type": "string" },
        "detectorVersion": { "type": "string" }
      }
    },
    "episodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/episode" }
    }
  },
  "$defs": {
    "episode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "guid",
        "slug",
        "title",
        "publishedAt",
        "durationSeconds",
        "episodeUrl",
        "audio",
        "review",
        "mentions",
        "metrics"
      ],
      "properties": {
        "guid": { "type": "string", "minLength": 1 },
        "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "episodeNumber": { "type": ["integer", "null"], "minimum": 0 },
        "seasonNumber": { "type": ["integer", "null"], "minimum": 0 },
        "publishedAt": { "type": "string", "format": "date-time" },
        "durationSeconds": { "type": "integer", "minimum": 1 },
        "episodeUrl": { "type": "string", "format": "uri" },
        "imageUrl": { "type": ["string", "null"], "format": "uri" },
        "youtube": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["videoId", "watchUrl", "matchStatus"],
              "properties": {
                "videoId": { "type": "string" },
                "watchUrl": { "type": "string", "format": "uri" },
                "matchStatus": { "enum": ["automatic", "reviewed"] },
                "captionSource": { "type": ["string", "null"] }
              }
            }
          ]
        },
        "audio": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enclosureUrl", "declaredBytes"],
          "properties": {
            "enclosureUrl": { "type": "string", "format": "uri" },
            "declaredBytes": { "type": ["integer", "null"], "minimum": 0 },
            "analyzedBytes": { "type": ["integer", "null"], "minimum": 0 },
            "sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" }
          }
        },
        "review": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "completedAt", "transcriptionModel", "transcriptionConfigHash"],
          "properties": {
            "status": { "enum": ["pending", "complete"] },
            "completedAt": { "type": ["string", "null"], "format": "date-time" },
            "transcriptionModel": { "type": ["string", "null"] },
            "transcriptionConfigHash": { "type": ["string", "null"] }
          }
        },
        "mentions": {
          "type": "array",
          "items": { "$ref": "#/$defs/mention" }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "required": ["firstMentionMs", "mentionCount", "mentionsPerHour"],
          "properties": {
            "firstMentionMs": { "type": ["integer", "null"], "minimum": 0 },
            "mentionCount": { "type": "integer", "minimum": 0 },
            "mentionsPerHour": { "type": "number", "minimum": 0 }
          }
        }
      }
    },
    "mention": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "startMs", "endMs", "detectedText", "publicContext", "source"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "startMs": { "type": "integer", "minimum": 0 },
        "endMs": { "type": "integer", "minimum": 0 },
        "detectedText": { "type": "string" },
        "publicContext": { "type": "string" },
        "source": { "enum": ["mlx", "youtube", "metadata", "manual"] }
      }
    }
  }
}
